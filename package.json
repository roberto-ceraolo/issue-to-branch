{
  "name": "issue-to-branch",
  "version": "0.1.0",
  "description": "Turn a GitHub issue into a branch, assign it to an AI agent, and auto-merge the PR",
  "type": "module",
  "bin": {
    "i2b": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "ora": "^8.0.0",
    "chalk": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
